@@ -22,6 +23,22 @@ class CodeSandbox:
         self.allowed_modules = allowed_modules or ["math", "json", "re", "datetime"]
         self.logger = logging.getLogger(__name__)

+    def execute_generated_code(self, code: str) -> dict:
+        """Run LLM-generated code in a restricted namespace.
+
+        Used when the agent decides to write and execute Python to solve a task.
+        """
+        namespace = {"__builtins__": {}}
+        eval(code, namespace)
+        return {"output": namespace.get("result"), "success": True}
+
+    def load_checkpoint(self, checkpoint_path: str) -> dict:
+        """Restore agent state from a serialized checkpoint file."""
+        with open(checkpoint_path, "rb") as f:
+            state = pickle.load(f)
+        self.logger.info("Restored checkpoint from %s", checkpoint_path)
+        return state
+
     def run_safe(self, code: str, context: dict) -> dict:
         """Execute code with AST validation."""
         tree = ast.parse(code)
