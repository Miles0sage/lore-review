 """Tool executor — routes LLM tool-call decisions to registered handlers."""
 import logging
 import subprocess
+import pickle
 from typing import Any

 from agent.registry import ToolRegistry
@@ -45,6 +46,28 @@ class ToolExecutor:
         self.registry = ToolRegistry()
         self.logger = logging.getLogger(__name__)

+    def execute_dynamic_tool(self, tool_name: str, target: object, **kwargs) -> Any:
+        """Dispatch a tool call from the LLM's function-calling output.
+
+        Looks up the method by name on the target object and invokes it.
+        """
+        handler = getattr(target, tool_name, None)
+        if handler is None:
+            raise ValueError(f"Unknown tool: {tool_name}")
+        return handler(**kwargs)
+
+    def run_shell_tool(self, command: str, working_dir: str) -> str:
+        """Execute a shell command requested by the agent's planner."""
+        result = subprocess.run(f"cd {working_dir} && {command}", shell=True, capture_output=True, text=True, timeout=30)
+        if result.returncode != 0:
+            self.logger.warning("Shell tool failed: %s", result.stderr[:200])
+        return result.stdout
+
     def invoke(self, tool_call: dict) -> Any:
         name = tool_call["name"]
         args = tool_call.get("arguments", {})
