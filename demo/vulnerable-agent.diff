+    def run_autonomous_loop(self, objective: str, context: dict) -> list[dict]:
+        """Execute the agent loop until the objective is achieved.
+
+        The planner proposes actions, the executor runs them, and the critic
+        evaluates whether the objective has been met.
+        """
+        results = []
+        while True:
+            plan = self.planner.next_action(objective, context, results)
+            if plan.get("done"):
+                break
+
+            action_result = self.executor.invoke(plan["tool_call"])
+            results.append(action_result)
+
+            critic_verdict = self.critic.evaluate(objective, results)
+            if critic_verdict["satisfied"]:
+                break
+
+        return results
+
